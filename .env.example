# StardustFS Central Server 환경변수 템플릿
# 이 파일을 .env로 복사한 후 값을 설정하세요.

# JWT 설정 (필수)
STARDUST_JWT_SECRET_KEY=your-secret-key-here

# 서버 설정
STARDUST_DEBUG=false
STARDUST_HOST=0.0.0.0
STARDUST_PORT=8000

# 데이터베이스
STARDUST_DATABASE_URL=data/stardustfs.db

# JWT 토큰 만료
STARDUST_ACCESS_TOKEN_EXPIRE_MINUTES=15
STARDUST_REFRESH_TOKEN_EXPIRE_DAYS=30

# OAuth - Google
STARDUST_GOOGLE_CLIENT_ID=
STARDUST_GOOGLE_CLIENT_SECRET=

# OAuth - GitHub
STARDUST_GITHUB_CLIENT_ID=
STARDUST_GITHUB_CLIENT_SECRET=

# Heartbeat 타임아웃 (분)
STARDUST_HEARTBEAT_TIMEOUT_MINUTES=5
